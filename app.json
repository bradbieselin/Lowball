{
  "expo": {
    "name": "Lowball",
    "slug": "lowball",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0D0D",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Lowball needs camera access to scan products and find deals.",
        "NSPhotoLibraryUsageDescription": "Lowball needs photo library access to scan products from your photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Lowball needs camera access to scan products and find deals."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Lowball needs photo library access to scan products from your photos."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "androidAppId": "ca-app-pub-3940256099942544~3347511713"
        }
      ],
      "expo-apple-authentication"
    ]
  }
}
